APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# IANA timezone for attendance timestamps (e.g. America/Chicago, Asia/Manila). Admins can override in Settings → timezone.
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Brevo transactional email (https://app.brevo.com) — used for contact, password reset, announcements, etc.
BREVO_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Driver verification vendor (liveness / ID / face)
VERIFICATION_API_KEY=

# DeepFace (Python-based). Start stack: cd python/deepface && python app.py
# Default UI/API in this repo's Python implementation: http://localhost:8225 (see DEEPFACE_HTTP_PORT there).
# Set up a Recognition app and optional Verification app; paste API keys below.
DEEPFACE_BASE_URL=http://localhost:8225
DEEPFACE_RECOGNITION_API_KEY=
DEEPFACE_VERIFICATION_API_KEY=
# Minimum 1:1 similarity (0–1) from Face Verification when comparing selfie to ID front
DEEPFACE_ID_MATCH_MINIMUM=0.72

# Google reCAPTCHA v2 (checkbox) for login — https://www.google.com/recaptcha/admin
# Both keys must be set for captcha to run. Set RECAPTCHA_ENABLED=false to turn it off (e.g. local dev
# when keys are tied to another domain, or while fixing verification) without changing keys.
# Avoid php artisan migrate:fresh to fix login; that drops all users. Use RECAPTCHA_ENABLED=false,
# or php artisan tinker to reset a password, instead.
RECAPTCHA_ENABLED=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
